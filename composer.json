{
    "name": "php-noobs/php-source-registry",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "PhpNoobs\\PhpSource\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PhpNoobs\\PhpSource\\Tests\\": "tests/"
        }
    },
    "require": {
        "php": ">=8.4",
        "nikic/php-parser": "^5.7",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.0",
        "friendsofphp/php-cs-fixer": "^3.95",
        "phpstan/phpstan-deprecation-rules": "^2.0"
    },
    "scripts": {
        "cs": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "test": "phpunit",
        "analyse": "phpstan analyse",
        "qa": [
            "@cs",
            "@analyse",
            "@test"
        ]
    }
}
